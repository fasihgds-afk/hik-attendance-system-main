# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# next-app build and dependencies
next-app/.next/
next-app/node_modules/

# sync-service (optional; exclude from repo if not needed)
/sync-service/

# agent-ts
agent-ts/node_modules/
agent-ts/data/

# agent (Python)
agent/**/__pycache__/
agent/build/
agent/dist/
agent/agent_data/
